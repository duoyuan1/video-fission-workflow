# The CLI loads .env from the repo root automatically.
# Keep real secrets in .env only. Do not commit them.

# Optional global fallback for any stage that does not define its own values.
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_AUTH_SCHEME=bearer

# Stage: analyze
# Recommended for source-video understanding.
ANALYZE_MODEL=qwen3-omni-flash
ANALYZE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ANALYZE_API_KEY=
ANALYZE_AUTH_SCHEME=bearer

# Stage group: planning
# Used by plan-directions / gen-script / gen-assets / gen-storyboards / qa.
# Example 1: DeepSeek official API
PLANNING_MODEL=deepseek-v4-pro
PLANNING_API_BASE=https://api.deepseek.com
PLANNING_API_KEY=
PLANNING_AUTH_SCHEME=bearer

# Example 2: yunwu.ai OpenAI-compatible gateway
# If you use yunwu instead of DeepSeek official API, replace the four values above with:
# PLANNING_MODEL=deepseek-v4-pro
# PLANNING_API_BASE=https://yunwu.ai/v1
# PLANNING_API_KEY=
# PLANNING_AUTH_SCHEME=raw

# Optional per-stage overrides if you want different planning models.
PLAN_MODEL=
PLAN_API_BASE=
PLAN_API_KEY=
PLAN_AUTH_SCHEME=

SCRIPT_MODEL=
SCRIPT_API_BASE=
SCRIPT_API_KEY=
SCRIPT_AUTH_SCHEME=

ASSET_MODEL=
ASSET_API_BASE=
ASSET_API_KEY=
ASSET_AUTH_SCHEME=

STORYBOARD_MODEL=
STORYBOARD_API_BASE=
STORYBOARD_API_KEY=
STORYBOARD_AUTH_SCHEME=

QA_MODEL=
QA_API_BASE=
QA_API_KEY=
QA_AUTH_SCHEME=

# Stage: render-videos
# Recommended starting point for yunwu.ai + Seedance 1.5 async video generation.
RENDER_PROVIDER=yunwu-seedance-1.5
RENDER_MODEL=doubao-seedance-1-5-pro-251215
RENDER_API_BASE=https://yunwu.ai
RENDER_API_KEY=
RENDER_AUTH_SCHEME=raw
RENDER_CREATE_PATH=/v1/videos
RENDER_STATUS_PATH=/v1/videos/{task_id}
RENDER_REQUEST_FORMAT=content
RENDER_DURATION=8
RENDER_RESOLUTION=
RENDER_SERVICE_TIER=
RENDER_GENERATE_AUDIO=true
RENDER_AUTO_POLL=true
RENDER_POLL_SECONDS=20
RENDER_MAX_POLLS=90

# Optional aliases for provider-specific secrets.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_AUTH_SCHEME=bearer

YUNWU_API_KEY=
YUNWU_BASE_URL=https://yunwu.ai/v1
YUNWU_AUTH_SCHEME=raw
